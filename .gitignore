# .gitignore
# Terraform state and sensitive files - never commit these

# Terraform state
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Sensitive variables - supply locally only
terraform.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
